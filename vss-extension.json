{
  "manifestVersion": 1,
  "id": "ado-boards-insights",
  "name": "ADO Boards Insights",
  "publisher": "NelsonLamprecht",
  "version": "0.1.0",
  "description": "Sums Story Points for the selected sprint and shows the total in the board header.",
  "targets": ["Microsoft.VisualStudio.Services"],
  "categories": ["Azure Boards"],
  "contributions": [
    {
      "id": "boards-storypoints-content",
      "type": "ms.vss-web.hub-content",
      "description": "Shows story points total for the sprint",
      "targets": ["ms.vss-work-web.board-hub"],
      "properties": {
        "name": "Boards Story Points",
        "uri": "content.html"
      }
    }
  ],
  "files": [
    { "path": "content.html" },
    { "path": "dist/content.js" },
    { "path": "README.md" }
  ]
}