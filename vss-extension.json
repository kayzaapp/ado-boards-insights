{
  "manifestVersion": 1,
  "id": "azure-devops-boards-insights",
  "name": "Azure DevOps Boards Insights",
  "publisher": "KayzaApplications",
  "version": "0.2.0",
  "description": "Shows total Story Points for backlog items.",
  "public": false,
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "categories": [
    "Azure Boards"
  ],
  "contributions": [
    {
      "id": "backlog-storypoints-content",
      "type": "ms.vss-web.hub-content",
      "description": "Shows story points total for the backlog",
      "targets": [
        "ms.vss-work-web.backlog-hub"
      ],
      "properties": {
        "name": "Backlog Story Points",
        "uri": "content.html"
      }
    }
  ],
  "files": [
    {
      "path": "content.html"
    },
    {
      "path": "dist/content.js"
    },
    {
      "path": "dist/content.js.map"
    },
    {
      "path": "src/styles.css"
    },
    {
      "path": "README.md"
    }
  ]
}
