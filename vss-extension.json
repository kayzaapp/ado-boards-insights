{
  "manifestVersion": 1,
  "id": "azure-devops-boards-insights",
  "name": "Azure DevOps Boards Insights",
  "publisher": "KayzaApplications",
  "version": "0.2.0",
  "description": "Shows total Story Points for visible backlog items.",
  "public": false,
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services.Cloud"
    }
  ],
  "categories": [
    "Azure Boards"
  ],
  "contributions": [
    {
      "id": "backlog-storypoints-action",
      "type": "ms.vss-web.action",
      "description": "Shows story points total for visible backlog items",
      "targets": [
        "ms.vss-work-web.backlog-toolbar-menu"
      ],
      "properties": {
        "text": "Story Points",
        "title": "Show Backlog Story Points Total",
        "icon": {
          "light": "img/icon.png",
          "dark": "img/icon.png"
        },
        "uri": "content.html"
      }
    }
  ],
  "files": [
    {
      "path": "content.html"
    },
    {
      "path": "dist/content.js"
    },
    {
      "path": "dist/content.js.map"
    },
    {
      "path": "src/styles.css"
    },
    {
      "path": "README.md"
    },
    {
      "path": "img",
      "addressable": true
    }
  ]
}
